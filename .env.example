# Copy to .env and fill in. .env is gitignored.

# The ID from your sheet's URL:
# https://docs.google.com/spreadsheets/d/THIS_PART/edit
SPREADSHEET_ID=

# Path to the service-account JSON key file (defaults to ./credentials.json).
# On Render, add the key as a Secret File named credentials.json (mounts at the
# project root, so this can stay unset), or point it at /etc/secrets/credentials.json.
# GOOGLE_CREDENTIALS_PATH=./credentials.json
